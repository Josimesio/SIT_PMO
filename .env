# ============================================================
# TIMEOUTS
# Valores em milissegundos.
# ============================================================
TIMEOUT_PADRAO=60000
TIMEOUT_DOWNLOAD=180000
TIMEOUT_LINHA_CURTO=5000

# Timeout TOTAL para procurar o link Edit dentro do cenário.
# Esse tempo é total para todas as tentativas, não por seletor.
TIMEOUT_EDIT_EXECUCAO=8000
INTERVALO_LOG_EDIT_SEGUNDOS=2
MAX_LINHAS_INEXISTENTES_SEGUIDAS=10

# ============================================================
# DOWNLOADS / PLACEHOLDER / CONSOLIDADO
# ============================================================
DOWNLOAD_DIR=downloads_gtn
GERAR_PLACEHOLDER_SEM_EDIT=S
TEMPLATE_NAO_INICIADO=modelo.xls

# S = gera consolidado final ao terminar os downloads.
# N = não gera consolidado final.
GERAR_CONSOLIDADO_FINAL=S

# S = exibe janela com tempo de execução.
# N = não exibe janela de tempo.
EXIBIR_TELA_TEMPO=S

# S = mantém navegador aberto no final esperando ENTER.
# N = fecha automaticamente após gerar o consolidado.
MANTER_NAVEGADOR_ABERTO=N

